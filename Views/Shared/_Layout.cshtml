<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - cicd</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/cicd.styles.css" asp-append-version="true" />
</head>
<body class="bg-devops">
    <div class="hero-bg"></div>
    <div class="topbar">
        <strong style="color:#22c55e;">CI/CD</strong> Dashboard
    </div>
    <div class="sidebar">
        <h3>⚙ DevOps</h3>
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <a href="#">Pipelines</a>
        <a href="#">Deployments</a>
        <a href="#">Logs</a>
        <a href="#">Settings</a>
    </div>

    <div class="main-content">

        <div class="topbar">
            <span>CI/CD Dashboard</span>
        </div>

        <div class="content-area">
            @RenderBody()
        </div>

    </div>

</body>
</html>
